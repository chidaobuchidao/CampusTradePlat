<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.KeywordTagMapper">

    <select id="matchKeyword" resultType="java.util.HashMap">
        SELECT category_id AS categoryId, tag_name AS tagName
        FROM keyword_tag
        WHERE keyword = #{keyword}
        LIMIT 1
    </select>

</mapper>
